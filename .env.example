# Local development only. Do not commit real secrets.
LLM_ENABLED=false
# Maximum independent row-level LLM requests in flight. Leave at the safe
# default of 8 unless the Azure deployment capacity requires a lower value.
LLM_MAX_CONCURRENCY=
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=example

# Required by `run` unless using --allow-local-vocabularies for offline review.
# Do not commit real tokens.
FACT_DATA_API_BASE_URL=
FACT_DATA_API_BEARER_TOKEN=
# Required when write actions are enabled. Use an existing FaCT user UUID so
# the API can attribute its audit records. Do not create a user automatically.
FACT_DATA_API_USER_ID=
# API execution is disabled unless this is explicitly set to true locally.
FACT_DATA_API_WRITES_ENABLED=false
# Optional: the importer verifies addresses through FaCT's existing
# /search/address endpoint. It never calls Ordnance Survey directly.
# Keep this at or above 1.0 seconds to respect the shared upstream limit.
OS_ADDRESS_MIN_INTERVAL_SECONDS=
# This is not read by the importer. It is here only as a local reminder that
# the separately running fact-data-api service requires its own OS credential.
# Do not commit a real value.
OS_KEY=
