#!/bin/sh

set -eu

echo "Running unit tests with coverage before push..."
PYTHON_BIN="python3"
if [ -x ".venv/bin/python3" ]; then
  PYTHON_BIN=".venv/bin/python3"
fi

if ! "$PYTHON_BIN" -c "import pytest_cov" >/dev/null 2>&1; then
  echo "pytest-cov is not installed. Run: sh scripts/bootstrap.sh" >&2
  exit 1
fi

"$PYTHON_BIN" -m pytest tests/unit --cov=fact_form_importer --cov-report=term-missing --cov-report=json:coverage.json
"$PYTHON_BIN" scripts/check_coverage.py coverage.json --fail-under 90 --core-fail-under 95
